rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /siteContent/current {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /quoteRequests/{requestId} {
      allow create: if request.resource.data.keys().hasOnly([
          "name",
          "phone",
          "email",
          "farmLocation",
          "message",
          "page",
          "status",
          "createdAt"
        ]) &&
        request.resource.data.name is string &&
        request.resource.data.phone is string &&
        request.resource.data.email is string &&
        request.resource.data.farmLocation is string &&
        request.resource.data.message is string &&
        request.resource.data.page is string &&
        request.resource.data.status is string &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.name.size() > 1 &&
        request.resource.data.phone.size() > 5 &&
        request.resource.data.email.size() > 5 &&
        request.resource.data.farmLocation.size() > 1 &&
        request.resource.data.message.size() > 5;

      allow read, update, delete: if isAdmin();
    }

    match /admins/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow write: if isAdmin();
    }
  }
}
